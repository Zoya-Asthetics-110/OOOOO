{
  "entities": {
    "Project": {
      "title": "Project",
      "description": "A portfolio project",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "Project title" },
        "category": { "type": "string", "description": "Project category" },
        "description": { "type": "string", "description": "Project description" },
        "image": { "type": "string", "description": "Project image URL" },
        "featured": { "type": "boolean", "description": "Whether the project is featured" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp" }
      },
      "required": ["title", "category", "description", "image"]
    },
    "Message": {
      "title": "Message",
      "description": "A contact form message",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Sender name" },
        "email": { "type": "string", "description": "Sender email" },
        "message": { "type": "string", "description": "Message content" },
        "date": { "type": "string", "format": "date-time", "description": "Message timestamp" },
        "read": { "type": "boolean", "description": "Whether the message has been read" }
      },
      "required": ["name", "email", "message", "date", "read"]
    }
  },
  "firestore": {
    "projects": {
      "schema": "Project",
      "description": "Collection of portfolio projects"
    },
    "messages": {
      "schema": "Message",
      "description": "Collection of contact messages"
    }
  }
}
